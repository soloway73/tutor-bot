# ===========================================
# Telegram Bot Configuration
# ===========================================
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ===========================================
# Google Calendar Configuration
# ===========================================
# Service Account JSON credentials (paste the entire JSON content as a single line)
# Get this from Google Cloud Console -> Service Accounts
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Calendar ID (use 'primary' for default calendar, or share a specific calendar with service account)
GOOGLE_CALENDAR_ID=primary

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
DB_USER=tutorbot
DB_PASSWORD=tutorbot_password
DB_NAME=tutorbot
DB_PORT=5432

# This is used by the application to connect to PostgreSQL
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}?schema=public

# ===========================================
# Application Configuration
# ===========================================
PORT=3000
NODE_ENV=development
